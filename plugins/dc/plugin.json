{
  "name": "dc",
  "version": "1.0.0",
  "description": "Docker compose command shortcuts",
  "author": "Martin Skalicky",
  "type": "script",
  "entry_point": "dc.sh",
  "category": "docker",
  "dependencies": {
    "apt": ["docker.io", "docker-compose"],
    "plugins": []
  },
  "help": {
    "usage": "dc <command> [args]",
    "description": "Convenient shortcuts for common docker compose commands. Provides short aliases for frequently used docker compose operations.",
    "options": [
      {
        "flag": "u, up",
        "description": "docker compose up"
      },
      {
        "flag": "ud, upd",
        "description": "docker compose up -d"
      },
      {
        "flag": "d, down",
        "description": "docker compose down"
      },
      {
        "flag": "r, restart",
        "description": "docker compose restart"
      },
      {
        "flag": "l, logs",
        "description": "docker compose logs -f"
      },
      {
        "flag": "ps",
        "description": "docker compose ps"
      }
    ],
    "examples": [
      {
        "command": "dc u",
        "description": "Start services (docker compose up)"
      },
      {
        "command": "dc d",
        "description": "Stop services (docker compose down)"
      }
    ]
  }
}
