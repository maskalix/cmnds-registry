{
  "name": "perf",
  "version": "2.0.0",
  "description": "System performance snapshot (CPU, memory, load, disk)",
  "author": "Martin Skalicky",
  "type": "binary",
  "entry_point": "perf",
  "category": "system",
  "dependencies": {
    "apt": [],
    "plugins": []
  },
  "help": {
    "usage": "perf [-w]",
    "description": "Reads /proc directly — no external tools required. Use -w for a self-refreshing snapshot.",
    "options": [
      { "flag": "-w, --watch", "description": "Refresh every 2 seconds" },
      { "flag": "-h, --help", "description": "Show this help" }
    ],
    "examples": [
      { "command": "perf", "description": "One-shot snapshot" },
      { "command": "perf -w", "description": "Live monitor" }
    ]
  }
}
