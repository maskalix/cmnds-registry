{
  "name": "a",
  "version": "1.0.0",
  "description": "Quick apt package manager shortcuts",
  "author": "Martin Skalicky",
  "type": "script",
  "entry_point": "a.sh",
  "category": "system",
  "dependencies": {
    "apt": [],
    "plugins": []
  },
  "help": {
    "usage": "a [-y] <command> [args]",
    "description": "Convenient shortcuts for apt package manager commands. Provides short aliases for common apt operations like install, update, upgrade, remove, etc.",
    "options": [
      {
        "flag": "-y",
        "description": "Automatically answer yes to prompts"
      },
      {
        "flag": "i, install",
        "description": "Install a package"
      },
      {
        "flag": "u, update",
        "description": "Update package lists"
      },
      {
        "flag": "ug, upgrade",
        "description": "Upgrade installed packages"
      },
      {
        "flag": "r, remove",
        "description": "Remove a package"
      },
      {
        "flag": "p, purge",
        "description": "Remove package with config files"
      },
      {
        "flag": "au, autoremove",
        "description": "Remove unused packages"
      },
      {
        "flag": "c, clean",
        "description": "Clear package cache"
      },
      {
        "flag": "h, help",
        "description": "Show help message"
      }
    ],
    "examples": [
      {
        "command": "a i nginx",
        "description": "Install nginx package"
      },
      {
        "command": "a -y ug",
        "description": "Upgrade all packages without prompts"
      },
      {
        "command": "a u",
        "description": "Update package lists"
      }
    ]
  }
}
