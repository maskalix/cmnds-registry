{
  "name": "cpc",
  "version": "2.0.0",
  "description": "Copy files from subfolders with progress bar",
  "author": "Martin Skalicky",
  "type": "binary",
  "entry_point": "cpc",
  "category": "files",
  "dependencies": {
    "apt": [],
    "plugins": []
  },
  "help": {
    "usage": "cpc <source> <destination>",
    "description": "Copies regular files from each immediate subfolder of <source> into a same-named subfolder under <destination>. Shows a progress bar per subfolder.",
    "options": [
      { "flag": "-h, --help", "description": "Show this help" },
      { "flag": "-src", "description": "Source folder (positional alternative)" },
      { "flag": "-dst", "description": "Destination folder (positional alternative)" }
    ],
    "examples": [
      { "command": "cpc /mnt/source /mnt/backup", "description": "Copy every subfolder of /mnt/source into /mnt/backup" }
    ]
  }
}
